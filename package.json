{
  "name": "charmap2",
  "private": true,
  "version": "0.1.0",
  "description": "A static Unicode character map for searching, inspecting, and copying Unicode characters.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://llaurila.github.io/charmap2/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/llaurila/charmap2.git"
  },
  "bugs": {
    "url": "https://github.com/llaurila/charmap2/issues"
  },
  "keywords": [
    "unicode",
    "character-map",
    "react",
    "vite",
    "search",
    "static-site"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "npm run generate:unicode && vite",
    "build": "npm run generate:unicode && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "vendor:unicode": "tsx scripts/unicode/vendor.ts",
    "generate:unicode": "tsx scripts/unicode/generate.ts"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
